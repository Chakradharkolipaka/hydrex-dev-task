{
  "name": "billion-towers",
  "version": "1.0.0",
  "description": "Billion Towers Real Estate Platform",
  "private": true,
  "main": "src/index.js",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.1.1",
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.294.0",
    "mongoose": "^8.3.2",
    "paytmchecksum": "^1.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "react-share": "^5.2.2",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "node server/server.js",
    "frontend": "react-app-rewired start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:goerli": "hardhat run scripts/deploy.js --network arbitrumGoerli",
    "contracts:deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrum",
    "audit:prod": "npm audit --omit=dev",
    "audit:prod:high": "npm audit --omit=dev --audit-level=high"
  },
  "proxy": "http://localhost:3099",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.3",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "crypto-browserify": "^3.12.1",
    "db-rake": "^1.0.0",
    "hardhat": "^2.17.0",
    "https-browserify": "^1.0.0",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "react-app-rewired": "^2.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.4"
  },
  "overrides": {
    "nth-check": "2.1.1",
    "@tootallnate/once": "3.0.1",
    "underscore": "1.13.8",
    "serialize-javascript": "7.0.5",
    "elliptic": "6.6.1",
    "bfj": "9.1.3",
    "postcss": "8.5.14",
    "yaml": "2.9.0"
  }
}

# ── Server & Frontend Config ───────────────────────────────────────────
# Note: PORT is intentionally left out or mapped carefully so React and Express don't conflict.
# React defaults to 3000. Express uses 3099 by default in server.js if PORT is missing.
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────
# MongoDB connection string
MONGO_URI=
# Fawn transaction collection name (used in dbConnection.js)
TRANS_COLL=transaction_collection

# ── JWT & Authentication ───────────────────────────────────────────────
JWT_SECRET=8f4a3c2b91e70d654f8b92837d6e5a4c3b2a19f8e7d6c5b4a3928173645a4b3c
JWT_EXPIRE=7d
COOKIE_EXPIRE=5
COOKIE_EXPIRES_TIME=5

# ── Third-Party APIs (Payments) ────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_SECRET_KEY=

PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CHANNEL_ID=WEB
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CUST_ID=

# ── Email Services ─────────────────────────────────────────────────────
# SMTP setup (used in sendEmail.js)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=gmail
SMTP_MAIL=
SMTP_PASSWORD=

# Alternative SMTP config (used in mailer.js)
ECOM_EMAIL=
ECOM_PASSWORD=

# Sendgrid setup (used in sendEmail.js & order/user controllers)
SENDGRID_API_KEY=
SENDGRID_MAIL=
SENDGRID_RESET_TEMPLATEID=
SENDGRID_ORDER_TEMPLATEID=

# ── Cloudinary (File/Image Uploads) ────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
